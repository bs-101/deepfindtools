APP_PORT=8080
LOCAL_NGINX_PORT=8080
PUBLIC_BASE_URL=https://www.deepfindtools.com

DB_ENGINE=django.db.backends.mysql
DB_NAME=adops_db
DB_USER=adops_user
DB_PASSWORD=change_this_database_password
MYSQL_ROOT_PASSWORD=change_this_mysql_root_password
DB_HOST=mysql
DB_PORT=3306

ADMIN_USER=admin
ADMIN_PASSWORD=change_this_admin_password

# Optional automation. Candidates are collected into the admin review queue only.
CANDIDATE_LIMIT=12
COLLECT_INTERVAL_SECONDS=3600
PRODUCT_HUNT_TOKEN=
LOGO_PREFETCH_LIMIT=260
TOOL_ENRICH_LIMIT=50

# Optional WeChat Official Account monitoring (We-MP-RSS sidecar).
# The management UI binds to localhost only and is not routed through Nginx.
WECHAT_RSS_PORT=8001
WECHAT_RSS_USER=admin
WECHAT_RSS_PASSWORD=change_this_wechat_rss_password
WECHAT_RSS_SECRET_KEY=change_this_long_random_secret
WECHAT_RSS_URL=http://we-mp-rss:8001/feed/all.json?limit=100
# Optional exact account names, comma-separated. Subscribing only to approved accounts is recommended.
WECHAT_ACCOUNT_ALLOWLIST=
